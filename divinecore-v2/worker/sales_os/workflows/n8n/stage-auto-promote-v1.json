    {
      "id": "node-extract-patrick",
      "name": "Extract Recipient (Patrick)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        280
      ],
      "parameters": {
        "jsCode": "const items = $input.all();\nconst out = [];\nfor (const it of items) {\n  const m = it.json;\n  function getHeader(name) {\n    const flat = m[name] || m[name.toLowerCase()];\n    if (flat) return flat;\n    const arr = (m.payload && m.payload.headers) || [];\n    const h = arr.find(x => (x.name || '').toLowerCase() === name.toLowerCase());\n    return h ? h.value : '';\n  }\n  const toRaw = getHeader('To') || '';\n  // Extract first email from \"Name <email>\" or plain \"email, email\"\n  const match = toRaw.match(/[\\w.+-]+@[\\w-]+\\.[\\w.-]+/);\n  if (!match) continue;\n  out.push({ json: {\n    inbox: 'patrick',\n    recipient_email: match[0].toLowerCase(),\n    thread_id: m.threadId || '',\n    message_id: m.id || '',\n    sent_at: parseInt(m.internalDate || '0'),\n  }});\n}\nreturn out;"
      }
    },
