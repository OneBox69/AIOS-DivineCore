        "jsCode": "const resp = $input.first().json;\nconst ctx = $('Pick Contact (or skip)').item.json;\nconst opps = (resp && resp.opportunities) || [];\n// Doppel-Filter: Stage muss NEW_REPLY sein (search query macht das schon, aber wir checken)\nconst opp = opps.find(o => o.pipelineStageId === '1fcfd0da-a41b-4c9a-adef-d3e3fca4ec15');\nif (!opp) return [{ json: { skip: true, reason: 'no_opp_in_new_reply' } }];\nreturn [{ json: {\n  skip: false,\n  opportunity_id: opp.id,\n  contact_id: ctx.contact_id,\n  contact_email: ctx.contact_email,\n  thread_id: ctx.thread_id,\n  inbox: ctx.inbox,\n}}];"
