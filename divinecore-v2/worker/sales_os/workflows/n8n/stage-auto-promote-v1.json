      "id": "node-pick-contact",
      "name": "Pick Contact (or skip)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        400
      ],
      "parameters": {
        "jsCode": "const lookupResp = $input.first().json;\nconst ctx = $('Merge').item.json;\nconst contacts = (lookupResp && lookupResp.contacts) || [];\n// Email match strict\nconst found = contacts.find(c => (c.email || '').toLowerCase() === ctx.recipient_email);\nif (!found) return [{ json: { skip: true, reason: 'no_contact' } }];\nreturn [{ json: {\n  skip: false,\n  contact_id: found.id,\n  contact_email: found.email,\n  contact_first_name: found.firstName || '',\n  contact_last_name: found.lastName || '',\n  recipient_email: ctx.recipient_email,\n  thread_id: ctx.thread_id,\n  inbox: ctx.inbox,\n}}];"
      }
    },
