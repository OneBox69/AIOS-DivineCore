# Copy this file to .env on the VPS (same directory as docker-compose.yml)
# .env is gitignored — never commit real keys.

# Fathom (used by the worker to poll for new meeting recordings every 10 min)
FATHOM_API_KEY=
# Optional overrides
# FATHOM_API_BASE_URL=https://api.fathom.ai/external/v1
# FATHOM_POLL_LOOKBACK_HOURS=24

# Supabase (system of record for Fathom Meetings + tasks)
# URL: https://<project-ref>.supabase.co
# Secret key: Supabase dashboard -> Settings -> API -> "Secret keys" (sb_secret_...)
# Required tables: see ops_os/integrations/fathom/.overview.md for the SQL.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# OpenRouter (used for meeting categorization fallback + Upwork pipeline)
OPENROUTER_API_KEY=
# Optional overrides
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# CATEGORIZER_MODEL=openai/gpt-4o-mini

# Upwork integration — Google OAuth (used to create Docs / share / append rows)
# Run `docker compose run --rm worker python -m sales_os.integrations.upwork.oauth_bootstrap` once
# to fetch the refresh token. See sales_os/integrations/upwork/.overview.md.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Optional overrides — template Doc / Sheet IDs default to the existing Pang-owned ones.
# UPWORK_PROPOSAL_TEMPLATE_ID=1BnxRE-zYcri2VuUD5g8M9dzs0sRfNgP2JGU3ek6ztlY
# UPWORK_TRACKING_SHEET_ID=1yW6xojrzpgj9fBVz3BD_d6PScVqp5XjlbxrD38iZtxU
# UPWORK_PROPOSAL_FIELDS_MODEL=openai/gpt-4o-mini
# UPWORK_APPLICATION_MODEL=openai/gpt-5.1

# Instantly integration — cold-email outreach (replies + daily analytics snapshot)
# Bearer token from Instantly Settings -> Integrations -> API Keys.
INSTANTLY_API_KEY=
# Shared secret Instantly sends in X-Webhook-Secret header on each webhook POST.
# Generate something long and random and paste the same value into Instantly's webhook config.
INSTANTLY_WEBHOOK_SECRET=
# Optional override
# INSTANTLY_API_BASE_URL=https://api.instantly.ai

# Discord — outreach replies destination (thread inside #sales-and-outreach).
# 1) Create a webhook on #sales-and-outreach -> save URL here.
# 2) Manually create a thread named "outreach-replies" in that channel; copy its ID here.
# See sales_os/integrations/instantly/.overview.md for the one-time setup walkthrough.
DISCORD_OUTREACH_WEBHOOK_URL=
DISCORD_OUTREACH_THREAD_ID=
