# Copy this file to .env on the VPS (same directory as docker-compose.yml)
# .env is gitignored — never commit real keys.

# Fathom (used by the worker to poll for new meeting recordings every 10 min)
FATHOM_API_KEY=
# Optional overrides
# FATHOM_API_BASE_URL=https://api.fathom.ai/external/v1
# FATHOM_POLL_LOOKBACK_HOURS=24

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
# Optional overrides (defaults: Meetings / Task)
# AIRTABLE_MEETINGS_TABLE=Meetings
# AIRTABLE_TASKS_TABLE=Task

# OpenRouter (used for meeting categorization fallback)
OPENROUTER_API_KEY=
# Optional overrides
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# CATEGORIZER_MODEL=openai/gpt-4o-mini
